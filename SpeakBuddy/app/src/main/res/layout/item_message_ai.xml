<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="4dp"
    android:paddingStart="12dp"
    android:paddingEnd="64dp">

    <!-- Correction card (only shown when mistakes exist) -->
    <LinearLayout
        android:id="@+id/layoutCorrection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_correction"
        android:padding="12dp"
        android:layout_marginBottom="4dp"
        android:maxWidth="280dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/grammar_corrections_title"
            android:textStyle="bold"
            android:textColor="#E65100"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvCorrections"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- AI reply bubble -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_ai"
        android:padding="12dp"
        android:maxWidth="280dp">

        <TextView
            android:id="@+id/tvAiReply"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:lineSpacingExtra="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvAiTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="11sp" />

            <ImageButton
                android:id="@+id/btnReplay"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_volume_up"
                android:scaleType="centerInside"
                android:contentDescription="@string/cd_replay"
                app:tint="@color/primary"
                xmlns:app="http://schemas.android.com/apk/res-auto" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
